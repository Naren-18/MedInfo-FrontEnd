# Copy this file to .env.local (already gitignored via the *.local pattern)
# and set the values you want. .env.local is only read by `npm run dev` —
# it controls where the Vite dev proxy forwards /api/* requests to.

# Local backend (default if this file/variable is absent):
# VITE_GATEWAY_URL=http://localhost:8080

# Railway-hosted backend:
VITE_GATEWAY_URL=https://gateway-service-production-2453.up.railway.app
